<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>DataFusionArena.Web</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Shared\DataFusionArena.Shared.csproj" />
  </ItemGroup>

  <!-- Copia SampleData al directorio de salida -->
  <ItemGroup>
    <None Update="..\SampleData\**\*.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>SampleData\%(Filename)%(Extension)</Link>
    </None>
  </ItemGroup>

</Project>
