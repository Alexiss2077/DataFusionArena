@model ClimaViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "API Clima";
    var fechasJson  = JsonSerializer.Serialize(Model.Fechas);
    var tmaxJson    = JsonSerializer.Serialize(Model.TempMax);
    var tminJson    = JsonSerializer.Serialize(Model.TempMin);
    var precipJson  = JsonSerializer.Serialize(Model.Precipitacion);
    var vientoJson  = JsonSerializer.Serialize(Model.Viento);
}

<!-- ─── PAGE TITLE ─────────────────────────────────────────── -->
<div class="page-title">
    <div>
        <h1 class="section-heading">API <em style="color:var(--acid)">climática</em></h1>
        <p class="section-sub">
            Open-Meteo · <span style="color:var(--acid)">@Model.Ciudad</span> · Pronóstico 14 días · Sin API key
        </p>
    </div>
    <form asp-action="IntegrarDatos" method="post">
        <button type="submit" class="btn btn-acid btn-sm">
            <i class="bi bi-plus-circle" style="font-size:11px"></i>
            Integrar al Dataset
        </button>
    </form>
</div>

<!-- ─── INFO BAR ──────────────────────────────────────────── -->
<div class="card mb-4" style="border-color:rgba(212,255,0,0.15)">
    <div class="card-body" style="display:flex; gap:16px; align-items:flex-start; padding:14px 16px">
        <div style="color:var(--acid); font-size:16px; flex-shrink:0; margin-top:2px">
            <i class="bi bi-broadcast"></i>
        </div>
        <div style="flex:1">
            <div style="font-family:var(--mono); font-size:11px; font-weight:500; color:var(--chalk); margin-bottom:4px">
                Bonus — API REST Externa
            </div>
            <div style="font-family:var(--mono); font-size:10px; color:var(--chalk-faint); line-height:1.8">
                Esta sección consume
                <a href="https://open-meteo.com" target="_blank" style="color:var(--acid)">api.open-meteo.com</a>
                en tiempo real. Los datos se transforman al modelo <code style="color:var(--sapphire)">DataItem</code>
                y pueden integrarse al dataset para análisis conjunto con archivos y bases de datos.
            </div>
        </div>
        <div style="flex-shrink:0; font-family:var(--mono); font-size:9px; color:var(--chalk-faint); text-align:right; line-height:2">
            <div style="color:var(--chalk-dim); margin-bottom:2px">ENDPOINT</div>
            <code style="font-size:9px; color:var(--sapphire)">api.open-meteo.com/v1/forecast</code>
        </div>
    </div>
</div>

@if (Model.ConError)
{
    <div class="card mb-4" style="border-color:rgba(255,61,107,0.3); background:rgba(255,61,107,0.04)">
        <div class="card-body" style="display:flex; gap:12px; align-items:center; padding:14px 16px">
            <i class="bi bi-exclamation-triangle" style="color:var(--rose); font-size:16px; flex-shrink:0"></i>
            <div>
                <div style="font-family:var(--mono); font-size:11px; font-weight:500; color:var(--rose)">Error de conexión</div>
                <div style="font-family:var(--mono); font-size:10px; color:var(--chalk-faint); margin-top:2px">@Model.MensajeError</div>
            </div>
        </div>
    </div>
}
else
{
    <!-- ─── WEATHER CARDS ─────────────────────────────────────── -->
    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--copper)"></span>
                Pronóstico — @Model.Ciudad
            </div>
            <span class="tag tag-dim" style="font-size:9px">14 días</span>
        </div>

        <div style="overflow-x:auto; padding:16px">
            <div style="display:flex; gap:8px; min-width:max-content">
                @foreach (var dia in Model.Pronostico)
                {
                    bool rain = dia.Precipitacion > 5;
                    bool hot  = dia.TempMax > 35;
                    <div style="width:90px; background:var(--ink-3); border:1px solid var(--ink-5); border-radius:var(--r-lg); padding:12px 8px; text-align:center; flex-shrink:0; transition:border-color 0.15s"
                         onmouseover="this.style.borderColor='var(--acid)'"
                         onmouseout="this.style.borderColor='var(--ink-5)'">
                        <div style="font-family:var(--mono); font-size:8px; color:var(--chalk-faint); margin-bottom:6px; letter-spacing:0.05em">
                            @dia.Fecha.Substring(5)
                        </div>
                        <div style="font-size:20px; margin-bottom:8px; line-height:1">@dia.IconoClima</div>
                        <div style="font-family:var(--mono); font-size:14px; font-weight:600; color:@(hot ? "var(--copper)" : "var(--chalk)"); margin-bottom:2px">
                            @dia.TempMax.ToString("F0")°
                        </div>
                        <div style="font-family:var(--mono); font-size:11px; color:var(--sapphire)">
                            @dia.TempMin.ToString("F0")°
                        </div>
                        @if (dia.Precipitacion > 0)
                        {
                            <div style="font-family:var(--mono); font-size:9px; color:@(rain ? "var(--sapphire)" : "var(--chalk-faint)"); margin-top:6px">
                                @dia.Precipitacion.ToString("F1")mm
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ─── CHARTS ────────────────────────────────────────────── -->
    <div class="grid grid-2 mb-4" style="grid-template-columns:2fr 1fr">
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-title-accent" style="background:var(--copper)"></span>
                    Temperatura Máx / Mín (°C)
                </div>
            </div>
            <div class="chart-wrap" style="height:260px">
                <canvas id="chartTemp"></canvas>
            </div>
        </div>
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-title-accent" style="background:var(--sapphire)"></span>
                    Precipitación (mm)
                </div>
            </div>
            <div class="chart-wrap" style="height:260px">
                <canvas id="chartPrecip"></canvas>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--malachite)"></span>
                Velocidad del Viento (km/h)
            </div>
        </div>
        <div class="chart-wrap" style="height:180px">
            <canvas id="chartViento"></canvas>
        </div>
    </div>

    <!-- ─── DATA TABLE ────────────────────────────────────────── -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--chalk-faint)"></span>
                Datos detallados
            </div>
        </div>
        <div class="table-scroll" style="max-height:360px">
            <table class="data-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Fecha</th>
                        <th style="text-align:right">T. Máx (°C)</th>
                        <th style="text-align:right">T. Mín (°C)</th>
                        <th style="text-align:right">Precipit. (mm)</th>
                        <th style="text-align:right">Viento (km/h)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dia in Model.Pronostico)
                    {
                        <tr>
                            <td style="font-size:16px; line-height:1; padding:8px 12px">@dia.IconoClima</td>
                            <td style="font-weight:500">@dia.Fecha</td>
                            <td style="text-align:right; color:@(dia.TempMax > 35 ? "var(--copper)" : "var(--chalk)")">
                                @dia.TempMax.ToString("F1")°
                            </td>
                            <td style="text-align:right; color:var(--sapphire)">
                                @dia.TempMin.ToString("F1")°
                            </td>
                            <td style="text-align:right; color:@(dia.Precipitacion > 5 ? "var(--sapphire)" : "var(--chalk-faint)")">
                                @dia.Precipitacion.ToString("F1")
                            </td>
                            <td class="num-cell">@dia.Viento.ToString("F0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ─── ENDPOINT CODE ────────────────────────────────────── -->
    <div class="card mt-4">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--malachite)"></span>
                Respuesta JSON — Open-Meteo
            </div>
            <span class="tag tag-malachite" style="font-size:9px">live</span>
        </div>
        <div class="card-body" style="padding:0">
            <pre style="border:none; border-radius:0; margin:0; max-height:200px; overflow-y:auto; font-size:10px">{
  "daily": {
    "time":               ["@(Model.Fechas.FirstOrDefault())", "@(Model.Fechas.Skip(1).FirstOrDefault())", "..."],
    "temperature_2m_max": [@(Model.TempMax.FirstOrDefault().ToString("F1")), @(Model.TempMax.Skip(1).FirstOrDefault().ToString("F1")), ...],
    "temperature_2m_min": [@(Model.TempMin.FirstOrDefault().ToString("F1")), @(Model.TempMin.Skip(1).FirstOrDefault().ToString("F1")), ...],
    "precipitation_sum":  [@(Model.Precipitacion.FirstOrDefault().ToString("F1")), ...],
    "windspeed_10m_max":  [@(Model.Viento.FirstOrDefault().ToString("F0")), ...]
  }
}</pre>
        </div>
    </div>
}

@section Scripts {
<script>
const GRID = 'rgba(255,255,255,0.05)';
const tip = {
    backgroundColor: '#1a1a26', borderColor: '#32324a', borderWidth: 1,
    borderRadius: 4, padding: 10,
    titleColor: '#d4ff00',
    titleFont: { family: "'JetBrains Mono'", size: 10, weight: '500' },
    bodyColor: '#e8e8f0',
    bodyFont: { family: "'JetBrains Mono'", size: 10 }
};
const scaleX = {
    grid: { color: GRID }, ticks: { font: { family:"'JetBrains Mono'", size:9 }, color:'#9090a8', maxRotation:45 }
};
const scaleY = (cb) => ({
    grid: { color: GRID }, ticks: { font: { family:"'JetBrains Mono'", size:9 }, color:'#9090a8', callback: cb || (v => v) }
});

new Chart(document.getElementById('chartTemp'), {
    type: 'line',
    data: {
        labels: @Html.Raw(fechasJson),
        datasets: [
            {
                label: 'T. Máx', data: @Html.Raw(tmaxJson),
                borderColor:'#ff6b35', backgroundColor:'rgba(255,107,53,0.08)',
                fill:false, tension:0.4, pointRadius:4,
                pointBackgroundColor:'#ff6b35', pointBorderColor:'#0a0a0f', pointBorderWidth:2
            },
            {
                label: 'T. Mín', data: @Html.Raw(tminJson),
                borderColor:'#3d8bff', backgroundColor:'rgba(61,139,255,0.08)',
                fill:false, tension:0.4, pointRadius:4,
                pointBackgroundColor:'#3d8bff', pointBorderColor:'#0a0a0f', pointBorderWidth:2
            }
        ]
    },
    options: {
        responsive:true, maintainAspectRatio:false,
        plugins: { tooltip:tip, legend:{ labels:{ font:{family:"'JetBrains Mono'",size:9}, color:'#9090a8', boxWidth:10, usePointStyle:true } } },
        scales: { x:scaleX, y:scaleY(v => v+'°C') }
    }
});

new Chart(document.getElementById('chartPrecip'), {
    type: 'bar',
    data: {
        labels: @Html.Raw(fechasJson),
        datasets: [{
            label: 'mm', data: @Html.Raw(precipJson),
            backgroundColor: 'rgba(61,139,255,0.25)', borderColor:'#3d8bff',
            borderWidth:1, borderRadius:2
        }]
    },
    options: {
        responsive:true, maintainAspectRatio:false,
        plugins: { legend:{ display:false }, tooltip:tip },
        scales: { x:scaleX, y:scaleY(v => v+' mm') }
    }
});

new Chart(document.getElementById('chartViento'), {
    type: 'line',
    data: {
        labels: @Html.Raw(fechasJson),
        datasets: [{
            label: 'km/h', data: @Html.Raw(vientoJson),
            borderColor:'#00d48a', backgroundColor:'rgba(0,212,138,0.08)',
            fill:true, tension:0.4, pointRadius:3,
            pointBackgroundColor:'#00d48a', pointBorderColor:'#0a0a0f', pointBorderWidth:2
        }]
    },
    options: {
        responsive:true, maintainAspectRatio:false,
        plugins: { legend:{ display:false }, tooltip:tip },
        scales: { x:scaleX, y:scaleY(v => v+' km/h') }
    }
});
</script>
}
