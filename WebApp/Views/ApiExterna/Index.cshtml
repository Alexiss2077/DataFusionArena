@model CoinGeckoViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "API CoinGecko";

    var categorias = Model.Monedas.GroupBy(m => m.Categoria)
        .Select(g => new { Cat = g.Key, Count = g.Count(), AvgPrice = g.Average(x => x.PrecioUsd) })
        .OrderByDescending(x => x.Count).ToList();

    var labelsJson  = JsonSerializer.Serialize(Model.Monedas.Take(15).Select(m => m.Simbolo).ToList());
    var preciosJson = JsonSerializer.Serialize(Model.Monedas.Take(15).Select(m => m.PrecioUsd).ToList());
    var cambiosJson = JsonSerializer.Serialize(Model.Monedas.Take(20).Select(m => m.Cambio24h).ToList());
    var cambiosLbl  = JsonSerializer.Serialize(Model.Monedas.Take(20).Select(m => m.Simbolo).ToList());
    var catLabels   = JsonSerializer.Serialize(categorias.Select(c => c.Cat).ToList());
    var catCounts   = JsonSerializer.Serialize(categorias.Select(c => c.Count).ToList());
}

<div class="page-title">
    <div>
        <h1 class="section-heading">API <em style="color:var(--acid)">CoinGecko</em></h1>
        <p class="section-sub">
            Top 50 criptomonedas · Precios en USD · Sin API key ·
            <span style="color:var(--acid)">@Model.Monedas.Count</span> monedas cargadas
        </p>
    </div>
    <form asp-action="IntegrarDatos" method="post">
        <button type="submit" class="btn btn-acid btn-sm">
            <i class="bi bi-plus-circle" style="font-size:11px"></i>
            Integrar al Dataset
        </button>
    </form>
</div>

<!-- INFO BAR -->
<div class="card mb-4" style="border-color:rgba(212,255,0,0.15)">
    <div class="card-body" style="display:flex;gap:16px;align-items:flex-start;padding:14px 16px">
        <div style="color:var(--acid);font-size:16px;flex-shrink:0;margin-top:2px">
            <i class="bi bi-broadcast"></i>
        </div>
        <div style="flex:1">
            <div style="font-family:var(--mono);font-size:11px;font-weight:500;color:var(--chalk);margin-bottom:4px">
                Bonus — API REST Externa · CoinGecko
            </div>
            <div style="font-family:var(--mono);font-size:10px;color:var(--chalk-faint);line-height:1.8">
                Consume
                <a href="https://api.coingecko.com" target="_blank" style="color:var(--acid)">api.coingecko.com</a>
                en tiempo real. Los datos se mapean al modelo
                <code style="color:var(--sapphire)">DataItem</code>:
                nombre = moneda · categoría = cap. de mercado · valor = precio USD ·
                campos extra = volumen, cambio 24h, máx/mín.
            </div>
        </div>
        <div style="flex-shrink:0;font-family:var(--mono);font-size:9px;color:var(--chalk-faint);text-align:right;line-height:2">
            <div style="color:var(--chalk-dim);margin-bottom:2px">ENDPOINT</div>
            <code style="font-size:9px;color:var(--sapphire)">/api/v3/coins/markets</code>
        </div>
    </div>
</div>

@if (Model.ConError)
{
    <div class="card mb-4" style="border-color:rgba(255,61,107,0.3);background:rgba(255,61,107,0.04)">
        <div class="card-body" style="display:flex;gap:12px;align-items:center;padding:14px 16px">
            <i class="bi bi-exclamation-triangle" style="color:var(--rose);font-size:16px;flex-shrink:0"></i>
            <div>
                <div style="font-family:var(--mono);font-size:11px;font-weight:500;color:var(--rose)">Error de conexión</div>
                <div style="font-family:var(--mono);font-size:10px;color:var(--chalk-faint);margin-top:2px">@Model.MensajeError</div>
            </div>
        </div>
    </div>
}
else
{
    <!-- STAT STRIP -->
    <div class="stat-grid mb-4">
        <div class="stat-cell">
            <span class="stat-label">Monedas</span>
            <span class="stat-value stat-value-acid">@Model.Monedas.Count</span>
            <span class="stat-detail">Top por cap. de mercado</span>
        </div>
        <div class="stat-cell">
            <span class="stat-label">Mayor precio</span>
            <span class="stat-value">$@Model.Monedas.OrderByDescending(m => m.PrecioUsd).First().PrecioUsd.ToString("N2")</span>
            <span class="stat-detail">@Model.Monedas.OrderByDescending(m => m.PrecioUsd).First().Simbolo</span>
        </div>
        <div class="stat-cell">
            <span class="stat-label">Mayor alza 24h</span>
            <span class="stat-value" style="color:var(--malachite)">
                +@Model.Monedas.OrderByDescending(m => m.Cambio24h).First().Cambio24h.ToString("F2")%
            </span>
            <span class="stat-detail">@Model.Monedas.OrderByDescending(m => m.Cambio24h).First().Simbolo</span>
        </div>
        <div class="stat-cell">
            <span class="stat-label">Mayor caída 24h</span>
            <span class="stat-value" style="color:var(--rose)">
                @Model.Monedas.OrderBy(m => m.Cambio24h).First().Cambio24h.ToString("F2")%
            </span>
            <span class="stat-detail">@Model.Monedas.OrderBy(m => m.Cambio24h).First().Simbolo</span>
        </div>
    </div>

    <!-- CHARTS -->
    <div class="grid grid-2 mb-4" style="grid-template-columns:2fr 1fr">
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-title-accent"></span>
                    Precio USD — Top 15
                </div>
            </div>
            <div class="chart-wrap" style="height:280px">
                <canvas id="chartPrecios"></canvas>
            </div>
        </div>
        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-title-accent" style="background:var(--copper)"></span>
                    Por categoría
                </div>
            </div>
            <div class="chart-wrap" style="height:260px;display:flex;align-items:center;justify-content:center">
                <canvas id="chartCategorias"></canvas>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--malachite)"></span>
                Cambio % 24h — Top 20
            </div>
        </div>
        <div class="chart-wrap" style="height:200px">
            <canvas id="chartCambios"></canvas>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--sapphire)"></span>
                Datos detallados
            </div>
            <span class="tag tag-dim" style="font-size:9px">Top 50</span>
        </div>
        <div class="table-scroll" style="max-height:480px">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Moneda</th>
                        <th>Símbolo</th>
                        <th>Categoría</th>
                        <th style="text-align:right">Precio USD</th>
                        <th style="text-align:right">Cambio 24h</th>
                        <th style="text-align:right">Cap. Mercado</th>
                        <th style="text-align:right">Volumen 24h</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Monedas)
                    {
                        string cambioColor = m.Cambio24h >= 0 ? "var(--malachite)" : "var(--rose)";
                        string cambioSign  = m.Cambio24h >= 0 ? "+" : "";
                        <tr>
                            <td style="color:var(--chalk-faint)">@m.Ranking</td>
                            <td style="font-weight:500">@m.Nombre</td>
                            <td><span class="tag tag-dim" style="font-size:9px">@m.Simbolo</span></td>
                            <td><span class="tag tag-sapphire" style="font-size:9px">@m.Categoria</span></td>
                            <td class="val-cell">$@m.PrecioUsd.ToString("N4")</td>
                            <td style="text-align:right;color:@cambioColor;font-family:var(--mono);font-size:11px">
                                @cambioSign@m.Cambio24h.ToString("F2")%
                            </td>
                            <td class="num-cell">$@(m.CapMercado / 1_000_000_000).ToString("F2")B</td>
                            <td class="num-cell">$@(m.Volumen24h  / 1_000_000_000).ToString("F2")B</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ENDPOINT -->
    <div class="card mt-4">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--malachite)"></span>
                Respuesta JSON — CoinGecko
            </div>
            <span class="tag tag-malachite" style="font-size:9px">live</span>
        </div>
        <div class="card-body" style="padding:0">
            <pre style="border:none;border-radius:0;margin:0;max-height:180px;overflow-y:auto;font-size:10px">[
  {
    "id":                          "@Model.Monedas.FirstOrDefault()?.Id",
    "name":                        "@Model.Monedas.FirstOrDefault()?.Nombre",
    "symbol":                      "@Model.Monedas.FirstOrDefault()?.Simbolo?.ToLower()",
    "current_price":               @Model.Monedas.FirstOrDefault()?.PrecioUsd.ToString("F2"),
    "market_cap":                  @Model.Monedas.FirstOrDefault()?.CapMercado.ToString("F0"),
    "price_change_percentage_24h": @Model.Monedas.FirstOrDefault()?.Cambio24h.ToString("F4"),
    "total_volume":                @Model.Monedas.FirstOrDefault()?.Volumen24h.ToString("F0"),
    "high_24h":                    @Model.Monedas.FirstOrDefault()?.Maximo24h.ToString("F2"),
    "low_24h":                     @Model.Monedas.FirstOrDefault()?.Minimo24h.ToString("F2")
  }, ...
]</pre>
        </div>
    </div>
}

@section Scripts {
<script>
const GRID = 'rgba(255,255,255,0.05)';
const tip = {
    backgroundColor:'#1a1a26',borderColor:'#32324a',borderWidth:1,
    borderRadius:4,padding:10,
    titleColor:'#d4ff00',titleFont:{family:"'JetBrains Mono'",size:10,weight:'500'},
    bodyColor:'#e8e8f0',bodyFont:{family:"'JetBrains Mono'",size:10}
};
const scaleX = { grid:{color:GRID}, ticks:{font:{family:"'JetBrains Mono'",size:9},color:'#9090a8',maxRotation:45} };

new Chart(document.getElementById('chartPrecios'), {
    type:'bar',
    data:{
        labels: @Html.Raw(labelsJson),
        datasets:[{
            label:'Precio USD',
            data: @Html.Raw(preciosJson),
            backgroundColor:'rgba(212,255,0,0.15)',
            borderColor:'#d4ff00',
            borderWidth:1,borderRadius:2
        }]
    },
    options:{
        responsive:true,maintainAspectRatio:false,
        plugins:{legend:{display:false},tooltip:tip},
        scales:{
            x:scaleX,
            y:{
                grid:{color:GRID},
                ticks:{
                    font:{family:"'JetBrains Mono'",size:9},color:'#9090a8',
                    callback:v => v>=1000 ? '$'+(v/1000).toFixed(0)+'K' : '$'+v
                }
            }
        }
    }
});

new Chart(document.getElementById('chartCategorias'), {
    type:'doughnut',
    data:{
        labels: @Html.Raw(catLabels),
        datasets:[{
            data: @Html.Raw(catCounts),
            backgroundColor:['rgba(212,255,0,0.25)','rgba(61,139,255,0.25)','rgba(0,212,138,0.25)','rgba(255,107,53,0.25)'],
            borderColor:['#d4ff00','#3d8bff','#00d48a','#ff6b35'],
            borderWidth:1
        }]
    },
    options:{
        responsive:true,maintainAspectRatio:false,cutout:'65%',
        plugins:{
            legend:{position:'bottom',labels:{font:{family:"'JetBrains Mono'",size:9},color:'#9090a8',padding:10,boxWidth:10,usePointStyle:true}},
            tooltip:tip
        }
    }
});

const cambioData  = @Html.Raw(cambiosJson);
const cambioLbls  = @Html.Raw(cambiosLbl);
new Chart(document.getElementById('chartCambios'), {
    type:'bar',
    data:{
        labels:cambioLbls,
        datasets:[{
            label:'Cambio 24h %',
            data:cambioData,
            backgroundColor:cambioData.map(v => v>=0 ? 'rgba(0,212,138,0.25)' : 'rgba(255,61,107,0.25)'),
            borderColor:cambioData.map(v => v>=0 ? '#00d48a' : '#ff3d6b'),
            borderWidth:1,borderRadius:2
        }]
    },
    options:{
        responsive:true,maintainAspectRatio:false,
        plugins:{legend:{display:false},tooltip:tip},
        scales:{
            x:scaleX,
            y:{
                grid:{color:GRID},
                ticks:{font:{family:"'JetBrains Mono'",size:9},color:'#9090a8',callback:v=>v+'%'}
            }
        }
    }
});
</script>
}
