<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Data Fusion Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --bg-dark:  #12121c;
            --bg-mid:   #1c1c2a;
            --bg-light: #2a2a3c;
            --bg-card:  #23233a;
            --fg:       #e6e6f0;
            --cyan:     #00c8dc;
            --yellow:   #ffc832;
            --green:    #00e080;
            --accent:   #006ec8;
        }
        body { background: var(--bg-dark); color: var(--fg); font-family: 'Segoe UI', sans-serif; }
        .navbar { background: var(--bg-mid) !important; border-bottom: 1px solid var(--bg-light); }
        .navbar-brand { color: var(--cyan) !important; font-weight: 700; letter-spacing: 1px; }
        .nav-link { color: var(--fg) !important; }
        .nav-link:hover, .nav-link.active { color: var(--cyan) !important; }
        .card { background: var(--bg-card); border: 1px solid var(--bg-light); color: var(--fg); }
        .card-header { background: var(--bg-light); border-bottom: 1px solid #3a3a58; }
        .table { color: var(--fg); }
        .table thead th { background: var(--bg-light); color: var(--cyan); border-color: #3a3a58; }
        .table tbody tr { border-color: #2e2e44; }
        .table tbody tr:hover { background: var(--bg-light); }
        .form-control, .form-select {
            background: var(--bg-mid); color: var(--fg);
            border: 1px solid #3a3a58;
        }
        .form-control:focus, .form-select:focus {
            background: var(--bg-light); color: var(--fg);
            border-color: var(--cyan); box-shadow: 0 0 0 .2rem rgba(0,200,220,.25);
        }
        .btn-primary   { background: var(--accent); border-color: var(--accent); }
        .btn-outline-cyan { color: var(--cyan); border-color: var(--cyan); }
        .btn-outline-cyan:hover { background: var(--cyan); color: #000; }
        .badge-fuente { font-size: .75em; }
        .stat-card { border-left: 3px solid var(--cyan); }
        .stat-card .stat-num { font-size: 1.8rem; font-weight: 700; color: var(--cyan); }
        footer { background: var(--bg-mid); border-top: 1px solid var(--bg-light); }
        .page-link { background: var(--bg-mid); color: var(--fg); border-color: #3a3a58; }
        .page-link:hover { background: var(--bg-light); color: var(--cyan); }
        .alert-success { background: rgba(0,224,128,.15); border-color: var(--green); color: var(--green); }
        .alert-danger  { background: rgba(255,80,100,.15); border-color: #ff5064; color: #ff9096; }
        pre { color: #a0d0ff; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            Data Fusion Arena
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Index" && ViewContext.RouteData.Values["controller"]?.ToString()=="Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-table"></i> Datos
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Graficas" ? "active" : "")"
                       asp-controller="Home" asp-action="Graficas">
                        <i class="bi bi-bar-chart-fill"></i> Gráficas
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="ApiExterna" ? "active" : "")"
                       asp-controller="ApiExterna" asp-action="Index">
                        <i class="bi bi-cloud-download-fill"></i> API Externa
                    </a>
                </li>
            </ul>
            <span class="navbar-text text-muted small">
                <i class=""></i> 
            </span>
        </div>
    </div>
</nav>

<main class="container-fluid py-3 px-4">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Ok"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</main>

<footer class="py-3 mt-4 text-center text-muted small">
    Data Fusion Arena · Administración y Organización de Datos · Ingeniería 4.º Semestre
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
