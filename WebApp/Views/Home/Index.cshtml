@model HomeViewModel
@{ ViewData["Title"] = "Datos"; }

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="mb-0" style="color:var(--cyan)">
            <i class="bi bi-table me-2"></i>Todos los Datos
            <span class="badge bg-secondary ms-2" style="font-size:.7em">@Model.TotalRegistros registros</span>
        </h4>
    </div>
    <div class="d-flex gap-2">
        <!-- ⭐ BOTÓN PRINCIPAL: Descargar Dataset Completo -->
        <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalDescargar">
            <i class="bi bi-cloud-download"></i> 
            <strong>📦 Dataset Completo</strong>
        </button>

        <!-- Cargar archivo -->
        <form asp-action="CargarArchivo" method="post" enctype="multipart/form-data" class="d-flex gap-2">
            <input type="file" name="archivo" accept=".json,.csv,.xml,.txt"
                   class="form-control form-control-sm" style="max-width:220px" required />
            <button type="submit" class="btn btn-sm btn-outline-cyan">
                <i class="bi bi-upload"></i> Cargar
            </button>
        </form>

        <!-- Navegar -->
        <a asp-action="Graficas" class="btn btn-sm btn-outline-warning">
            <i class="bi bi-bar-chart"></i> Gráficas
        </a>
    </div>
</div>

<!-- MODAL DESCARGA DATASET -->
<div class="modal fade" id="modalDescargar" tabindex="-1" aria-labelledby="modalDescargaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--bg-card); border-color: var(--bg-light); border: 2px solid var(--bg-light)">
            
            <div class="modal-header" style="border-bottom: 2px solid var(--cyan)">
                <h5 class="modal-title" id="modalDescargaLabel" style="color: var(--cyan); font-weight: 700">
                    <i class="bi bi-cloud-download"></i> Descargar Dataset Completo
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body" style="padding: 2rem">
                <!-- Información -->
                <div class="alert alert-success" style="background: rgba(0,224,128,.15); border-color: #00e080; color: var(--fg); margin-bottom: 1.5rem">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>Información del Dataset:</strong>
                    <ul class="mb-0 mt-2 ps-4">
                        <li>✅ <strong>@Model.TotalRegistros registros</strong> totales acumulados</li>
                        <li>✅ Incluye datos cargados (JSON, CSV, XML, TXT)</li>
                        <li>✅ Incluye datos integrados de API (clima)</li>
                        <li>✅ Incluye datos de bases de datos (si existen)</li>
                        <li>✅ Timestamp automático: dataset_YYYY-MM-DD_HH-MM-SS.formato</li>
                    </ul>
                </div>

                <p style="margin-bottom: 1.5rem; font-size: 0.95rem">
                    <strong>📥 Selecciona el formato:</strong>
                </p>

                <!-- Opciones de descarga -->
                <div class="d-grid gap-2">
                    
                    <!-- CSV -->
                    <a href="/descargar-datos?formato=csv" 
                       class="btn btn-outline-success btn-lg d-flex align-items-center justify-content-between p-3"
                       onclick="descargarArchivo(event)">
                        <div class="text-start">
                            <div class="fw-bold">📄 CSV (Recomendado)</div>
                            <small class="text-muted">Compatible con Excel, Sheets, Python, R</small>
                        </div>
                        <i class="bi bi-download" style="font-size: 1.5rem; opacity: 0.5"></i>
                    </a>

                    <!-- EXCEL -->
                    <a href="/descargar-datos?formato=excel" 
                       class="btn btn-outline-warning btn-lg d-flex align-items-center justify-content-between p-3"
                       onclick="descargarArchivo(event)">
                        <div class="text-start">
                            <div class="fw-bold">📊 Excel (.xlsx)</div>
                            <small class="text-muted">Formato Microsoft Office con estilos</small>
                        </div>
                        <i class="bi bi-download" style="font-size: 1.5rem; opacity: 0.5"></i>
                    </a>

                    <!-- ESTADÍSTICAS -->
                    <a href="/descargar-estadisticas" 
                       class="btn btn-outline-info btn-lg d-flex align-items-center justify-content-between p-3"
                       onclick="descargarArchivo(event)">
                        <div class="text-start">
                            <div class="fw-bold">📈 Estadísticas</div>
                            <small class="text-muted">Resumen por categoría (CSV)</small>
                        </div>
                        <i class="bi bi-download" style="font-size: 1.5rem; opacity: 0.5"></i>
                    </a>

                </div>
            </div>

            <div class="modal-footer" style="border-top: 1px solid var(--bg-light); padding: 1rem">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <small class="text-muted ms-auto">💡 Usa los botones de arriba para descargar</small>
            </div>

        </div>
    </div>
</div>

<!-- Filtros -->
<form method="get" class="card mb-3 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted">Buscar en</label>
            <select name="campo" class="form-select form-select-sm">
                @foreach (var c in new[]{"nombre","categoria","fuente","id","valor"})
                {
                    <option value="@c" selected="@(Model.Campo==c)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label small text-muted">Valor</label>
            <input name="busqueda" value="@Model.Busqueda"
                   class="form-control form-control-sm" placeholder="Escribe para filtrar..." />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Fuente</label>
            <select name="fuente" class="form-select form-select-sm">
                <option value="">— Todas —</option>
                @foreach (var f in Model.Fuentes)
                {
                    <option value="@f" selected="@(Model.FuenteActiva==f)">@f</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm flex-fill">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">✖</a>
        </div>
    </div>
</form>

<!-- Tabla -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center py-2">
        <span class="small fw-bold">
            Página @Model.Pagina de @Model.TotalPaginas
            &nbsp;·&nbsp; Mostrando @Model.Datos.Count de @Model.TotalRegistros
        </span>
        <a asp-action="Graficas" class="btn btn-sm btn-outline-cyan">
            <i class="bi bi-bar-chart"></i> Ver Gráficas
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th class="text-end">Valor</th>
                    <th>Fecha</th>
                    <th>Fuente</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Datos.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Sin resultados</td></tr>
                }
                @foreach (var item in Model.Datos)
                {
                    <tr>
                        <td class="text-muted small">@item.Id</td>
                        <td>@item.Nombre</td>
                        <td><span class="badge" style="background:var(--bg-light);color:var(--fg)">@item.Categoria</span></td>
                        <td class="text-end fw-bold" style="color:var(--yellow)">@item.Valor.ToString("N2")</td>
                        <td class="small text-muted">@item.Fecha.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                var color = item.Fuente switch {
                                    "json"          => "success",
                                    "csv"           => "warning",
                                    "xml"           => "info",
                                    "txt"           => "secondary",
                                    "postgresql"    => "primary",
                                    "mariadb"       => "danger",
                                    "api-open-meteo"=> "light",
                                    _               => "dark"
                                };
                            }
                            <span class="badge bg-@color badge-fuente">@item.Fuente</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPaginas > 1)
    {
        <div class="card-footer d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Pagina==1?"disabled":"")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(Model.Pagina-1)"
                           asp-route-busqueda="@Model.Busqueda"
                           asp-route-campo="@Model.Campo"
                           asp-route-fuente="@Model.FuenteActiva">‹</a>
                    </li>
                    @for (int p = Math.Max(1, Model.Pagina - 3);
                          p <= Math.Min(Model.TotalPaginas, Model.Pagina + 3); p++)
                    {
                        <li class="page-item @(p==Model.Pagina?"active":"")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@p"
                               asp-route-busqueda="@Model.Busqueda"
                               asp-route-campo="@Model.Campo"
                               asp-route-fuente="@Model.FuenteActiva">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Pagina==Model.TotalPaginas?"disabled":"")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(Model.Pagina+1)"
                           asp-route-busqueda="@Model.Busqueda"
                           asp-route-campo="@Model.Campo"
                           asp-route-fuente="@Model.FuenteActiva">›</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<style>
.badge-fuente {
    font-size: .75em;
    font-weight: 600;
    padding: 0.4rem 0.6rem;
}

/* Botón principal con animación */
.btn-success {
    background-color: #00e080 !important;
    border-color: #00e080 !important;
    color: #000 !important;
    font-weight: 600;
    animation: pulse-green 2s infinite;
}

.btn-success:hover {
    background-color: #00cc70 !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 224, 128, 0.3);
    animation: none;
}

@@keyframes pulse-green {
    0%, 100% { 
        box-shadow: 0 0 0 0 rgba(0, 224, 128, 0.7);
    }
    50% {
        box-shadow: 0 0 0 8px rgba(0, 224, 128, 0);
    }
}

/* Botones en modal */
.btn-outline-success:hover {
    background-color: #00e080 !important;
    color: #000 !important;
    border-color: #00e080 !important;
}

.btn-outline-warning:hover {
    background-color: #ffc832 !important;
    color: #000 !important;
    border-color: #ffc832 !important;
}

.btn-outline-info:hover {
    background-color: #00c8dc !important;
    color: #000 !important;
    border-color: #00c8dc !important;
}
</style>

<script>
// Función para descargar archivo
function descargarArchivo(event) {
    event.preventDefault();
    
    const url = event.currentTarget.getAttribute('href');
    console.log('Descargando desde:', url);
    
    // Crear un elemento <a> temporal para la descarga
    const link = document.createElement('a');
    link.href = url;
    link.download = '';
    
    // Agregar a DOM, hacer click y remover
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    
    // Cerrar modal
    const modal = bootstrap.Modal.getInstance(document.getElementById('modalDescargar'));
    if (modal) {
        modal.hide();
    }
}
</script>
