@model HomeViewModel
@{ ViewData["Title"] = "Datos"; }

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="mb-0" style="color:var(--cyan)">
            <i class="bi bi-table me-2"></i>Todos los Datos
            <span class="badge bg-secondary ms-2" style="font-size:.7em">@Model.TotalRegistros registros</span>
        </h4>
    </div>
    <div class="d-flex gap-2">
        <!-- ⭐ BOTÓN PRINCIPAL: Descargar Dataset Completo -->
        <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#modalDescargar" title="Descarga el dataset completo con todos los datos acumulados incluyendo API">
            <i class="bi bi-cloud-download"></i> 
            <strong>📦 Descargar Dataset Completo</strong>
        </button>

        <!-- Cargar archivo -->
        <form asp-action="CargarArchivo" method="post" enctype="multipart/form-data" class="d-flex gap-2">
            <input type="file" name="archivo" accept=".json,.csv,.xml,.txt"
                   class="form-control form-control-sm" style="max-width:220px" required />
            <button type="submit" class="btn btn-sm btn-outline-cyan">
                <i class="bi bi-upload"></i> Cargar
            </button>
        </form>

        <!-- Navegar -->
        <a asp-action="Graficas" class="btn btn-sm btn-outline-warning">
            <i class="bi bi-bar-chart"></i> Gráficas
        </a>
    </div>
</div>

<!-- Modal para seleccionar formato de descarga -->
<div class="modal fade" id="modalDescargar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--bg-card); border-color: var(--bg-light)">
            <div class="modal-header" style="border-bottom-color: var(--bg-light)">
                <h5 class="modal-title" style="color: var(--cyan)">
                    <i class="bi bi-cloud-download"></i> Descargar Dataset Completo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info alert-dismissible fade show" style="background: rgba(0,200,220,.15); border-color: var(--cyan); color: var(--fg)">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Información del Dataset:</strong>
                    <ul class="mb-0 mt-2">
                        <li>✅ @Model.TotalRegistros registros totales acumulados</li>
                        <li>✅ Incluye todos los datos cargados y de API integrados</li>
                        <li>✅ Timestamp automático en el nombre del archivo</li>
                    </ul>
                </div>

                <p class="text-muted mb-3">Selecciona el formato de descarga:</p>

                <div class="row g-2">
                    <!-- Opción CSV -->
                    <div class="col-12">
                        <a href="@Url.Action("DescargarDatos", "Home", new { formato = "csv" })" 
                           class="btn btn-outline-success w-100 py-3" 
                           data-bs-dismiss="modal">
                            <i class="bi bi-file-earmark-csv"></i>
                            <div>
                                <strong>CSV (Recomendado)</strong>
                                <small class="d-block text-muted">Compatible con Excel, Sheets, Python, R</small>
                            </div>
                        </a>
                    </div>

                    <!-- Opción Excel -->
                    <div class="col-12">
                        <a href="@Url.Action("DescargarDatos", "Home", new { formato = "excel" })" 
                           class="btn btn-outline-warning w-100 py-3" 
                           data-bs-dismiss="modal">
                            <i class="bi bi-file-earmark-excel"></i>
                            <div>
                                <strong>Excel (.xlsx)</strong>
                                <small class="d-block text-muted">Formato Microsoft Office con estilos</small>
                            </div>
                        </a>
                    </div>

                    <!-- Opción Estadísticas -->
                    <div class="col-12">
                        <a href="@Url.Action("DescargarEstadisticas", "Home")" 
                           class="btn btn-outline-info w-100 py-3" 
                           data-bs-dismiss="modal">
                            <i class="bi bi-graph-up"></i>
                            <div>
                                <strong>Estadísticas</strong>
                                <small class="d-block text-muted">Resumen por categoría (CSV)</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top-color: var(--bg-light)">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    Cancelar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<form method="get" class="card mb-3 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted">Buscar en</label>
            <select name="campo" class="form-select form-select-sm">
                @foreach (var c in new[]{"nombre","categoria","fuente","id","valor"})
                {
                    <option value="@c" selected="@(Model.Campo==c)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label small text-muted">Valor</label>
            <input name="busqueda" value="@Model.Busqueda"
                   class="form-control form-control-sm" placeholder="Escribe para filtrar..." />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Fuente</label>
            <select name="fuente" class="form-select form-select-sm">
                <option value="">— Todas —</option>
                @foreach (var f in Model.Fuentes)
                {
                    <option value="@f" selected="@(Model.FuenteActiva==f)">@f</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm flex-fill">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">✖</a>
        </div>
    </div>
</form>

<!-- Tabla -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center py-2">
        <span class="small fw-bold">
            Página @Model.Pagina de @Model.TotalPaginas
            &nbsp;·&nbsp; Mostrando @Model.Datos.Count de @Model.TotalRegistros
        </span>
        <a asp-action="Graficas" class="btn btn-sm btn-outline-cyan">
            <i class="bi bi-bar-chart"></i> Ver Gráficas
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th class="text-end">Valor</th>
                    <th>Fecha</th>
                    <th>Fuente</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Datos.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Sin resultados</td></tr>
                }
                @foreach (var item in Model.Datos)
                {
                    <tr>
                        <td class="text-muted small">@item.Id</td>
                        <td>@item.Nombre</td>
                        <td><span class="badge" style="background:var(--bg-light);color:var(--fg)">@item.Categoria</span></td>
                        <td class="text-end fw-bold" style="color:var(--yellow)">@item.Valor.ToString("N2")</td>
                        <td class="small text-muted">@item.Fecha.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                var color = item.Fuente switch {
                                    "json"          => "success",
                                    "csv"           => "warning",
                                    "xml"           => "info",
                                    "txt"           => "secondary",
                                    "postgresql"    => "primary",
                                    "mariadb"       => "danger",
                                    "api-open-meteo"=> "light",
                                    _               => "dark"
                                };
                                var icon = item.Fuente switch {
                                    "json"          => "🟢",
                                    "csv"           => "📊",
                                    "xml"           => "📄",
                                    "txt"           => "📝",
                                    "postgresql"    => "🐘",
                                    "mariadb"       => "🐬",
                                    "api-open-meteo"=> "⛅",
                                    _               => "📦"
                                };
                            }
                            <span class="badge bg-@color badge-fuente" title="@item.Fuente">
                                @icon @item.Fuente
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPaginas > 1)
    {
        <div class="card-footer d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Pagina==1?"disabled":"")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(Model.Pagina-1)"
                           asp-route-busqueda="@Model.Busqueda"
                           asp-route-campo="@Model.Campo"
                           asp-route-fuente="@Model.FuenteActiva">‹</a>
                    </li>
                    @for (int p = Math.Max(1, Model.Pagina - 3);
                          p <= Math.Min(Model.TotalPaginas, Model.Pagina + 3); p++)
                    {
                        <li class="page-item @(p==Model.Pagina?"active":"")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@p"
                               asp-route-busqueda="@Model.Busqueda"
                               asp-route-campo="@Model.Campo"
                               asp-route-fuente="@Model.FuenteActiva">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Pagina==Model.TotalPaginas?"disabled":"")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(Model.Pagina+1)"
                           asp-route-busqueda="@Model.Busqueda"
                           asp-route-campo="@Model.Campo"
                           asp-route-fuente="@Model.FuenteActiva">›</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<style>
.badge-fuente {
    font-size: .75em;
    font-weight: 600;
    padding: 0.4rem 0.6rem;
}

/* Estilos para el modal */
.modal-content {
    border: 1px solid var(--bg-light);
}

.modal-header .btn-close {
    filter: invert(1);
}

.btn-outline-success:hover {
    background-color: #00e080;
    color: #000;
    border-color: #00e080;
}

.btn-outline-warning:hover {
    background-color: #ffc832;
    color: #000;
    border-color: #ffc832;
}

.btn-outline-info:hover {
    background-color: #00c8dc;
    color: #000;
    border-color: #00c8dc;
}

/* Botón principal destacado */
.btn-success {
    background-color: #00e080 !important;
    border-color: #00e080 !important;
    color: #000 !important;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-success:hover {
    background-color: #00cc70 !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 224, 128, 0.3);
}

.btn-success:active {
    transform: translateY(0);
}

/* Animación pulse para el botón principal */
@@keyframes pulse-green {
    0%, 100% { 
        box-shadow: 0 0 0 0 rgba(0, 224, 128, 0.7);
    }
    50% {
        box-shadow: 0 0 0 8px rgba(0, 224, 128, 0);
    }
}

.btn-success {
    animation: pulse-green 2s infinite;
}

.btn-success:hover {
    animation: none;
}
</style>
