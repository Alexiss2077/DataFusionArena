@model HomeViewModel
@using DataFusionArena.Web.Helpers
@{ ViewData["Title"] = "Dataset"; }

@{
    bool hayDatos = Model.TotalRegistros > 0;
    bool hayColumnas = Model.Columnas.Count > 0;

    var columnasNumericas = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    if (hayColumnas && Model.Datos.Any())
    {
        foreach (var col in Model.Columnas)
        {
            if (DataItemHelper.EsColumnaNumerica(Model.Datos, col, Model.Mapeo))
                columnasNumericas.Add(col);
        }
    }

    string SrcClass(string fuente) => fuente switch {
        "json"           => "src-json",
        "csv"            => "src-csv",
        "xml"            => "src-xml",
        "txt"            => "src-txt",
        "postgresql"     => "src-postgresql",
        "mariadb"        => "src-mariadb",
        "api-open-meteo" => "src-api",
        _ => ""
    };

    string SrcTagClass(string fuente) => fuente switch {
        "json"           => "tag tag-malachite",
        "csv"            => "tag tag-copper",
        "xml"            => "tag tag-sapphire",
        "txt"            => "tag tag-dim",
        "postgresql"     => "tag tag-acid",
        "mariadb"        => "tag tag-rose",
        "api-open-meteo" => "tag tag-dim",
        _ => "tag tag-dim"
    };
}

<!-- ─── PAGE TITLE ─────────────────────────────────────────── -->
<div class="page-title">
    <div>
        <h1 class="section-heading">Data Fusion <em style="color:var(--acid)">Arena</em></h1>
        <p class="section-sub">
            @if (hayDatos)
            {
                <span class="text-mono" style="color:var(--acid)">@Model.TotalRegistros.ToString("N0")</span>
                <span> registros · @Model.Columnas.Count columnas · @Model.Fuentes.Count fuentes</span>
            }
            else
            {
                <span>Sin datos — carga un archivo para comenzar</span>
            }
        </p>
    </div>

    <div class="flex gap-2 items-center" style="flex-shrink:0">
        @if (hayDatos)
        {
            <button onclick="openModal('modal-dl')" class="btn btn-acid btn-sm">
                <i class="bi bi-cloud-arrow-down" style="font-size:13px"></i>
                Exportar
            </button>
        }

        <form asp-action="CargarArchivo" method="post" enctype="multipart/form-data"
              class="flex gap-2 items-center">
            <input type="file" name="archivo" accept=".json,.csv,.xml,.txt"
                   style="max-width:200px; font-size:11px" required />
            <button type="submit" class="btn btn-ghost btn-sm">
                <i class="bi bi-upload" style="font-size:11px"></i>
                Cargar
            </button>
        </form>

        @if (hayDatos)
        {
            <a asp-action="Graficas" class="btn btn-outline-acid btn-sm">
                <i class="bi bi-activity" style="font-size:11px"></i>
                Análisis
            </a>
        }
    </div>
</div>

<!-- ─── SOURCE LEGEND ─────────────────────────────────────── -->
@if (hayDatos && Model.Fuentes.Any())
{
    <div class="flex gap-3 items-center mb-4 flex-wrap"
         style="padding: 10px 14px; background:var(--ink-2); border:1px solid var(--ink-4); border-radius:var(--r-lg)">
        <span class="text-mono text-faint" style="font-size:9px; text-transform:uppercase; letter-spacing:0.1em">Fuentes:</span>
        @foreach (var f in Model.Fuentes)
        {
            <span class="@SrcTagClass(f)">@f</span>
        }
    </div>
}

@if (!hayDatos)
{
    <!-- ─── EMPTY STATE ─────────────────────────────────────────── -->
    <div class="card" style="border-style:dashed">
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-database-slash"></i></div>
            <div class="empty-title">Sin datos cargados</div>
            <div class="empty-body">
                Carga un archivo JSON, CSV, XML o TXT para comenzar a explorar y fusionar tus datasets.
            </div>
            <div class="flex gap-2 mt-4">
                <span class="tag tag-malachite">JSON</span>
                <span class="tag tag-copper">CSV</span>
                <span class="tag tag-sapphire">XML</span>
                <span class="tag tag-dim" style="color:#a855f7; border-color:rgba(168,85,247,0.3); background:rgba(168,85,247,0.08)">TXT</span>
            </div>
        </div>
    </div>
}
else
{
    <!-- ─── FILTER BAR ──────────────────────────────────────────── -->
    <form method="get">
        <div class="filter-bar">
            <div class="filter-group">
                <span class="filter-label">Buscar en</span>
                <select name="campo" class="form-select" style="width:160px">
                    @foreach (var col in Model.Columnas)
                    {
                        <option value="@col" selected="@(Model.Campo == col)">@col</option>
                    }
                </select>
            </div>

            <div class="filter-group" style="flex:1; min-width:180px">
                <span class="filter-label">Valor</span>
                <div class="flex gap-2">
                    <input name="busqueda" value="@Model.Busqueda"
                           class="form-control" placeholder="Filtrar registros..."
                           style="flex:1" />
                </div>
            </div>

            <div class="filter-group">
                <span class="filter-label">Fuente</span>
                <select name="fuente" class="form-select" style="width:140px">
                    <option value="">— Todas —</option>
                    @foreach (var f in Model.Fuentes)
                    {
                        <option value="@f" selected="@(Model.FuenteActiva == f)">@f</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <span class="filter-label">&nbsp;</span>
                <div class="flex gap-2">
                    <button type="submit" class="btn btn-acid btn-sm">
                        <i class="bi bi-search" style="font-size:11px"></i>
                        Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-ghost btn-sm">
                        <i class="bi bi-x" style="font-size:13px"></i>
                    </a>
                </div>
            </div>

            <div class="ml-auto flex gap-2 items-center" style="align-self:flex-end">
                <span class="text-mono text-faint" style="font-size:9px">
                    pág. @Model.Pagina / @Model.TotalPaginas
                </span>
            </div>
        </div>
    </form>

    <!-- ─── TABLE ────────────────────────────────────────────────── -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent"></span>
                Registros
                <span style="color:var(--chalk-faint); font-weight:300">
                    — mostrando @Model.Datos.Count de @Model.TotalRegistros
                </span>
            </div>
            <div class="flex gap-2 items-center">
                <span class="text-mono text-faint" style="font-size:9px">@Model.Columnas.Count cols</span>
                <a asp-action="Graficas" class="btn btn-ghost btn-sm">
                    <i class="bi bi-bar-chart-line" style="font-size:11px"></i>
                    Gráficas
                </a>
            </div>
        </div>

        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        @foreach (var col in Model.Columnas)
                        {
                            bool esNum = columnasNumericas.Contains(col);
                            <th style="@(esNum ? "text-align:right" : "")">@col</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Datos.Any())
                    {
                        <tr>
                            <td colspan="@Model.Columnas.Count" class="text-center"
                                style="padding: 40px; color: var(--chalk-faint); font-family:var(--mono); font-size:11px">
                                Sin resultados para la búsqueda
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model.Datos)
                    {
                        string fuente = item.Fuente ?? "";
                        <tr class="@SrcClass(fuente)">
                            @foreach (var col in Model.Columnas)
                            {
                                string val = DataItemHelper.ObtenerValor(item, col, Model.Mapeo);
                                bool esNum = columnasNumericas.Contains(col);
                                string clave = Model.Mapeo.TryGetValue(col, out var mk) ? mk.ToLower() : col.ToLower();

                                if (string.Equals(clave, "fuente", StringComparison.OrdinalIgnoreCase)
                                    || string.Equals(col, "fuente", StringComparison.OrdinalIgnoreCase))
                                {
                                    <td><span class="@SrcTagClass(val)">@val</span></td>
                                }
                                else if (string.Equals(clave, "categoria", StringComparison.OrdinalIgnoreCase))
                                {
                                    <td><span class="tag tag-dim" style="font-size:9px">@val</span></td>
                                }
                                else if (string.Equals(clave, "valor", StringComparison.OrdinalIgnoreCase))
                                {
                                    <td class="val-cell">
                                        @if (double.TryParse(val, System.Globalization.NumberStyles.Any,
                                            System.Globalization.CultureInfo.InvariantCulture, out double dv))
                                        { @dv.ToString("N2") }
                                        else { @val }
                                    </td>
                                }
                                else if (esNum)
                                {
                                    <td class="num-cell">@val</td>
                                }
                                else
                                {
                                    <td style="max-width:220px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">@val</td>
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPaginas > 1)
        {
            <div class="card-footer" style="display:flex; align-items:center; justify-content:center; gap:16px">
                <nav>
                    <ul class="pagination">
                        <li class="page-item @(Model.Pagina == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@(Model.Pagina - 1)"
                               asp-route-busqueda="@Model.Busqueda"
                               asp-route-campo="@Model.Campo"
                               asp-route-fuente="@Model.FuenteActiva">‹</a>
                        </li>
                        @for (int p = Math.Max(1, Model.Pagina - 3);
                              p <= Math.Min(Model.TotalPaginas, Model.Pagina + 3); p++)
                        {
                            <li class="page-item @(p == Model.Pagina ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-pagina="@p"
                                   asp-route-busqueda="@Model.Busqueda"
                                   asp-route-campo="@Model.Campo"
                                   asp-route-fuente="@Model.FuenteActiva">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Pagina == Model.TotalPaginas ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@(Model.Pagina + 1)"
                               asp-route-busqueda="@Model.Busqueda"
                               asp-route-campo="@Model.Campo"
                               asp-route-fuente="@Model.FuenteActiva">›</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
}

<!-- ─── EXPORT MODAL ─────────────────────────────────────────── -->
<div class="modal-backdrop" id="modal-dl" onclick="if(event.target===this)closeModal('modal-dl')">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title">
                <i class="bi bi-cloud-arrow-down" style="color:var(--acid); margin-right:6px"></i>
                Exportar Dataset
            </span>
            <button class="modal-close" onclick="closeModal('modal-dl')">✕</button>
        </div>
        <div class="modal-body">
            <div style="margin-bottom:16px; padding:12px; background:rgba(212,255,0,0.04); border:1px solid rgba(212,255,0,0.15); border-radius:var(--r)">
                <div class="text-mono text-faint" style="font-size:9px; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:8px">Resumen</div>
                <div class="flex gap-4">
                    <div>
                        <div class="stat-label">Registros</div>
                        <div style="font-family:var(--serif); font-size:24px; color:var(--acid)">@Model.TotalRegistros.ToString("N0")</div>
                    </div>
                    <div>
                        <div class="stat-label">Columnas</div>
                        <div style="font-family:var(--serif); font-size:24px; color:var(--chalk)">@Model.Columnas.Count</div>
                    </div>
                    <div>
                        <div class="stat-label">Fuentes</div>
                        <div style="font-family:var(--serif); font-size:24px; color:var(--chalk)">@Model.Fuentes.Count</div>
                    </div>
                </div>
            </div>

            <div style="display:flex; flex-direction:column; gap:8px">
                <a href="/descargar-datos?formato=csv"
                   class="btn btn-ghost"
                   style="justify-content:space-between; padding:14px 16px;"
                   onclick="closeModal('modal-dl')">
                    <div class="flex gap-3 items-center">
                        <span class="tag tag-malachite">CSV</span>
                        <div>
                            <div style="font-size:12px; font-weight:500; color:var(--chalk)">Comma-Separated Values</div>
                            <div style="font-size:10px; color:var(--chalk-faint); margin-top:2px">Excel · Python · R · análisis universal</div>
                        </div>
                    </div>
                    <i class="bi bi-download" style="opacity:0.5"></i>
                </a>
                <a href="/descargar-datos?formato=excel"
                   class="btn btn-ghost"
                   style="justify-content:space-between; padding:14px 16px;"
                   onclick="closeModal('modal-dl')">
                    <div class="flex gap-3 items-center">
                        <span class="tag tag-acid">XLSX</span>
                        <div>
                            <div style="font-size:12px; font-weight:500; color:var(--chalk)">Excel Workbook</div>
                            <div style="font-size:10px; color:var(--chalk-faint); margin-top:2px">Microsoft Office · Google Sheets</div>
                        </div>
                    </div>
                    <i class="bi bi-download" style="opacity:0.5"></i>
                </a>
                <a href="/descargar-estadisticas"
                   class="btn btn-ghost"
                   style="justify-content:space-between; padding:14px 16px;"
                   onclick="closeModal('modal-dl')">
                    <div class="flex gap-3 items-center">
                        <span class="tag tag-sapphire">STATS</span>
                        <div>
                            <div style="font-size:12px; font-weight:500; color:var(--chalk)">Estadísticas por categoría</div>
                            <div style="font-size:10px; color:var(--chalk-faint); margin-top:2px">Promedio · Máx · Mín · Total</div>
                        </div>
                    </div>
                    <i class="bi bi-download" style="opacity:0.5"></i>
                </a>
            </div>
        </div>
        <div class="modal-footer">
            <button onclick="closeModal('modal-dl')" class="btn btn-ghost btn-sm">Cerrar</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openModal(id) {
    document.getElementById(id).classList.add('open');
}
function closeModal(id) {
    document.getElementById(id).classList.remove('open');
}
</script>
}
