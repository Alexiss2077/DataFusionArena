@model GraficasViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Gráficas";
    var catJson    = JsonSerializer.Serialize(Model.Categorias);
    var totJson    = JsonSerializer.Serialize(Model.Totales);
    var fuenteJson = JsonSerializer.Serialize(Model.Fuentes);
    var conteoJson = JsonSerializer.Serialize(Model.ConteoFuente);
    var fechasJson = JsonSerializer.Serialize(Model.Fechas);
    var valFecJson = JsonSerializer.Serialize(Model.ValoresFecha);

    var palette = new[]{"#00c8dc","#ffc832","#00e080","#ff5064",
                        "#b464ff","#ff9632","#00dcc8","#dc50dc",
                        "#50c850","#6496ff","#ff6e6e","#64ffb4"};
    var paletteJson = JsonSerializer.Serialize(palette);
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 style="color:var(--cyan); margin-bottom:0">
            <i class="bi bi-bar-chart-fill me-2"></i>Dashboard de Análisis
        </h4>
        <p class="text-muted small mb-0">Visualización completa de datos por categoría, fuente y período</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("DescargarEstadisticas", "Home")" class="btn btn-sm btn-outline-success">
            <i class="bi bi-download"></i> Descargar Estadísticas
        </a>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-table"></i> Ver Tabla
        </a>
    </div>
</div>

<!-- Tarjetas de resumen mejoradas -->
<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card stat-card-primary">
            <div class="stat-icon">
                <i class="bi bi-list-ul"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Total Registros</div>
                <div class="stat-value">@Model.TotalItems.ToString("N0")</div>
                <div class="stat-detail">Datos acumulados</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card stat-card-yellow">
            <div class="stat-icon">
                <i class="bi bi-folder-fill"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Categorías</div>
                <div class="stat-value">@Model.Categorias.Count</div>
                <div class="stat-detail">Grupos únicos</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card stat-card-green">
            <div class="stat-icon">
                <i class="bi bi-link-45deg"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Fuentes</div>
                <div class="stat-value">@Model.Fuentes.Count</div>
                <div class="stat-detail">Orígenes de datos</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card stat-card-danger">
            <div class="stat-icon">
                <i class="bi bi-calendar3"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">Períodos</div>
                <div class="stat-value">@Model.Fechas.Count</div>
                <div class="stat-detail">Línea temporal</div>
            </div>
        </div>
    </div>
</div>

<!-- Gráficas principales -->
<div class="row g-3">
    <!-- Gráfica 1: Barras por categoría (GRANDE) -->
    <div class="col-lg-8">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-gradient-cyan">
                <i class="bi bi-bar-chart me-2"></i>
                <strong>Valor Total por Categoría</strong>
                <span class="badge bg-dark ms-2">@Model.Categorias.Count categorías</span>
            </div>
            <div class="card-body" style="position: relative; height: 400px;">
                <canvas id="chartCat"></canvas>
            </div>
            <div class="card-footer text-muted small">
                <i class="bi bi-info-circle"></i> Los valores se muestran en unidades totales acumuladas por categoría
            </div>
        </div>
    </div>

    <!-- Gráfica 2: Dona por fuente -->
    <div class="col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-gradient-yellow">
                <i class="bi bi-pie-chart me-2"></i>
                <strong>Distribución por Fuente</strong>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="height: 400px;">
                <canvas id="chartFuente"></canvas>
            </div>
            <div class="card-footer text-muted small">
                <i class="bi bi-info-circle"></i> Porcentaje de registros por origen
            </div>
        </div>
    </div>

    <!-- Gráfica 3: Línea por fecha (ANCHO COMPLETO) -->
    @if (Model.Fechas.Any())
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-gradient-green">
                    <i class="bi bi-graph-up me-2"></i>
                    <strong>Tendencia Temporal</strong>
                    <span class="badge bg-dark ms-2">@Model.Fechas.Count períodos</span>
                </div>
                <div class="card-body" style="position: relative; height: 300px;">
                    <canvas id="chartFecha"></canvas>
                </div>
                <div class="card-footer text-muted small">
                    <i class="bi bi-info-circle"></i> Valor acumulado por período (mes)
                </div>
            </div>
        </div>
    }
</div>

<!-- Tabla resumen de categorías -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark border-top border-cyan">
                <strong class="text-cyan">
                    <i class="bi bi-table me-2"></i>Resumen por Categoría
                </strong>
                <a href="@Url.Action("DescargarEstadisticas", "Home")" class="btn btn-sm btn-outline-success float-end">
                    <i class="bi bi-download"></i> Descargar
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-dark table-hover mb-0">
                    <thead>
                        <tr style="border-top: 2px solid var(--cyan)">
                            <th style="color: var(--cyan); font-weight: 700">Categoría</th>
                            <th class="text-end" style="color: #ffc832">Cantidad</th>
                            <th class="text-end" style="color: #00e080">Promedio</th>
                            <th class="text-end" style="color: #ff5064">Máximo</th>
                            <th class="text-end" style="color: #6496ff">Mínimo</th>
                            <th class="text-end" style="color: var(--cyan); font-weight: 700">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int contador = 0;
                            foreach (var cat in Model.Categorias.Take(10))
                            {
                                var idx = Model.Categorias.IndexOf(cat);
                                <tr style="opacity: @(1 - contador * 0.05)">
                                    <td style="color: @(palette[idx % palette.Length]); font-weight: 600">
                                        <i class="bi bi-square-fill" style="font-size: 0.6rem; color: @(palette[idx % palette.Length])"></i>
                                        @cat
                                    </td>
                                    <td class="text-end fw-bold">@Model.Totales[idx]</td>
                                    <td class="text-end">@(Model.Totales[idx] > 0 ? (Model.Totales[idx] / contador).ToString("F2") : "0.00")</td>
                                    <td class="text-end">@Model.Totales[idx]</td>
                                    <td class="text-end">0.00</td>
                                    <td class="text-end fw-bold" style="color: var(--cyan)">@Model.Totales[idx].ToString("N2")</td>
                                </tr>
                                contador++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const PALETTE = @Html.Raw(paletteJson);
const dark = '#12121c', grid = '#2a2a3c', fg = '#e6e6f0';

Chart.defaults.color = fg;
Chart.defaults.font.family = "'Segoe UI', sans-serif";
Chart.defaults.plugins.legend.labels.padding = 15;

const tooltipDark = {
    backgroundColor: '#1c1c2a',
    borderColor: '#3a3a58',
    borderWidth: 2,
    borderRadius: 6,
    padding: 12,
    titleColor: '#00c8dc',
    titleFont: { weight: 'bold', size: 13 },
    bodyColor: '#e6e6f0',
    bodyFont: { size: 12 }
};

// ── 1. Barras por categoría (GRANDE y mejorado) ──────────────────
const ctxCat = document.getElementById('chartCat');
const chartCat = new Chart(ctxCat, {
    type: 'bar',
    data: {
        labels: @Html.Raw(catJson),
        datasets: [{
            label: 'Valor Total',
            data: @Html.Raw(totJson),
            backgroundColor: PALETTE,
            borderWidth: 2,
            borderColor: PALETTE,
            borderRadius: 8,
            borderSkipped: false,
            hoverBackgroundColor: PALETTE.map(c => c + 'dd')
        }]
    },
    options: {
        indexAxis: 'x',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { 
                display: true,
                labels: { usePointStyle: true, padding: 20 }
            },
            tooltip: { 
                ...tooltipDark,
                callbacks: {
                    label: ctx => {
                        const val = ctx.parsed.y;
                        let formatted;
                        if (val >= 1e6) formatted = (val / 1e6).toFixed(1) + 'M';
                        else if (val >= 1e3) formatted = (val / 1e3).toFixed(1) + 'K';
                        else formatted = val.toFixed(2);
                        return ` Valor: ${formatted}`;
                    }
                }
            }
        },
        scales: {
            x: { 
                grid: { color: grid, display: false }, 
                ticks: { maxRotation: 45, minRotation: 0 },
                stacked: false
            },
            y: { 
                grid: { color: grid, drawBorder: false },
                ticks: { 
                    callback: v => {
                        if (v >= 1e6) return (v / 1e6).toFixed(1) + 'M';
                        if (v >= 1e3) return (v / 1e3).toFixed(0) + 'K';
                        return v;
                    }
                },
                stacked: false
            }
        }
    }
});

// ── 2. Dona por fuente ───────────────────────────────────────
const ctxFuente = document.getElementById('chartFuente');
const chartFuente = new Chart(ctxFuente, {
    type: 'doughnut',
    data: {
        labels: @Html.Raw(fuenteJson),
        datasets: [{
            data: @Html.Raw(conteoJson),
            backgroundColor: PALETTE.slice(0, @Model.Fuentes.Count),
            borderWidth: 3,
            borderColor: dark,
            hoverBorderColor: '#00c8dc'
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '65%',
        plugins: {
            legend: { 
                position: 'bottom', 
                labels: { 
                    boxWidth: 14,
                    padding: 15,
                    usePointStyle: true,
                    pointStyle: 'circle'
                } 
            },
            tooltip: {
                ...tooltipDark,
                callbacks: {
                    label: ctx => {
                        const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                        const percent = ((ctx.parsed / total) * 100).toFixed(1);
                        return ` ${ctx.label}: ${ctx.parsed} registros (${percent}%)`;
                    }
                }
            }
        }
    }
});

@if (Model.Fechas.Any())
{
    <text>
// ── 3. Línea temporal (mejorada) ─────────────────────────────
const ctxFecha = document.getElementById('chartFecha');
const chartFecha = new Chart(ctxFecha, {
    type: 'line',
    data: {
        labels: @Html.Raw(fechasJson),
        datasets: [{
            label: 'Valor Acumulado',
            data: @Html.Raw(valFecJson),
            borderColor: '#00e080',
            backgroundColor: 'rgba(0,224,128,.15)',
            fill: true,
            tension: .5,
            pointRadius: 5,
            pointBackgroundColor: '#00e080',
            pointBorderColor: '#fff',
            pointBorderWidth: 2,
            pointHoverRadius: 7,
            pointHoverBackgroundColor: '#00e080'
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { 
                display: true,
                labels: { usePointStyle: true, padding: 20 }
            },
            tooltip: {
                ...tooltipDark,
                mode: 'index',
                intersect: false,
                callbacks: {
                    label: ctx => {
                        const val = ctx.parsed.y;
                        let formatted;
                        if (val >= 1e6) formatted = (val / 1e6).toFixed(2) + 'M';
                        else if (val >= 1e3) formatted = (val / 1e3).toFixed(1) + 'K';
                        else formatted = val.toFixed(2);
                        return ` ${formatted}`;
                    }
                }
            }
        },
        scales: {
            x: { 
                grid: { color: grid, display: false },
                ticks: { maxRotation: 45 }
            },
            y: { 
                grid: { color: grid, drawBorder: false },
                ticks: {
                    callback: v => {
                        if (v >= 1e6) return (v / 1e6).toFixed(1) + 'M';
                        if (v >= 1e3) return (v / 1e3).toFixed(0) + 'K';
                        return v;
                    }
                }
            }
        }
    }
});
    </text>
}
</script>

<style>
.bg-gradient-cyan {
    background: linear-gradient(135deg, #006b8f 0%, #00c8dc 100%);
    color: white;
    border: none;
}
.bg-gradient-yellow {
    background: linear-gradient(135deg, #b3860a 0%, #ffc832 100%);
    color: white;
    border: none;
}
.bg-gradient-green {
    background: linear-gradient(135deg, #006b35 0%, #00e080 100%);
    color: white;
    border: none;
}

.stat-card {
    background: var(--bg-card);
    border: 2px solid var(--bg-light);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s ease;
    cursor: pointer;
}

.stat-card:hover {
    transform: translateY(-4px);
    border-color: currentColor;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
}

.stat-card-primary {
    border-color: var(--cyan);
}
.stat-card-primary:hover {
    color: var(--cyan);
}

.stat-card-yellow {
    border-color: var(--yellow);
}
.stat-card-yellow:hover {
    color: var(--yellow);
}

.stat-card-green {
    border-color: var(--green);
}
.stat-card-green:hover {
    color: var(--green);
}

.stat-card-danger {
    border-color: #ff5064;
}
.stat-card-danger:hover {
    color: #ff5064;
}

.stat-icon {
    font-size: 2rem;
    opacity: 0.8;
    min-width: 50px;
    text-align: center;
}

.stat-content {
    flex: 1;
}

.stat-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0.7;
    margin-bottom: 0.3rem;
}

.stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.5px;
}

.stat-detail {
    font-size: 0.75rem;
    opacity: 0.6;
    margin-top: 0.2rem;
}

.card {
    border: 1px solid var(--bg-light);
    background: var(--bg-card);
}

.card-header {
    border-bottom: 2px solid rgba(0, 200, 220, 0.3);
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
}

.card-footer {
    border-top: 1px solid var(--bg-light);
    padding: 0.75rem 1.25rem;
}

.table-dark tbody tr:hover {
    background-color: var(--bg-light) !important;
}
</style>
}
