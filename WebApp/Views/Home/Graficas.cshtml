@model GraficasViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Análisis";
    var catJson    = JsonSerializer.Serialize(Model.Categorias);
    var totJson    = JsonSerializer.Serialize(Model.Totales);
    var fuenteJson = JsonSerializer.Serialize(Model.Fuentes);
    var conteoJson = JsonSerializer.Serialize(Model.ConteoFuente);
    var fechasJson = JsonSerializer.Serialize(Model.Fechas);
    var valFecJson = JsonSerializer.Serialize(Model.ValoresFecha);

    var palette = new[] {
        "#d4ff00","#ff6b35","#3d8bff","#00d48a",
        "#ff3d6b","#a855f7","#f59e0b","#06b6d4",
        "#84cc16","#ec4899","#f97316","#14b8a6"
    };
    var paletteJson = JsonSerializer.Serialize(palette);
}

<!-- ─── PAGE TITLE ─────────────────────────────────────────── -->
<div class="page-title">
    <div>
        <h1 class="section-heading">Análisis <em style="color:var(--acid)">visual</em></h1>
        <p class="section-sub">@Model.TotalItems.ToString("N0") registros · @Model.Categorias.Count categorías · @Model.Fuentes.Count fuentes</p>
    </div>
    <div class="flex gap-2 items-center" style="flex-shrink:0">
        <a href="/descargar-estadisticas" class="btn btn-ghost btn-sm">
            <i class="bi bi-download" style="font-size:11px"></i>
            Estadísticas CSV
        </a>
        <a asp-action="Index" class="btn btn-outline-acid btn-sm">
            <i class="bi bi-table" style="font-size:11px"></i>
            Dataset
        </a>
    </div>
</div>

<!-- ─── STAT STRIP ─────────────────────────────────────────── -->
<div class="stat-grid mb-6">
    <div class="stat-cell">
        <span class="stat-label">Total Registros</span>
        <span class="stat-value stat-value-acid">@Model.TotalItems.ToString("N0")</span>
        <span class="stat-detail">Datos acumulados</span>
    </div>
    <div class="stat-cell">
        <span class="stat-label">Categorías</span>
        <span class="stat-value">@Model.Categorias.Count</span>
        <span class="stat-detail">Grupos únicos</span>
    </div>
    <div class="stat-cell">
        <span class="stat-label">Fuentes</span>
        <span class="stat-value">@Model.Fuentes.Count</span>
        <span class="stat-detail">Orígenes de datos</span>
    </div>
    <div class="stat-cell">
        <span class="stat-label">Períodos</span>
        <span class="stat-value">@Model.Fechas.Count</span>
        <span class="stat-detail">Línea temporal</span>
    </div>
</div>

<!-- ─── CHARTS ROW 1 ──────────────────────────────────────── -->
<div class="grid grid-2 mb-4" style="grid-template-columns:2fr 1fr">
    <!-- Bar chart: categorías -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent"></span>
                Valor total por categoría
            </div>
            <span class="tag tag-dim" style="font-size:9px">@Model.Categorias.Count cats.</span>
        </div>
        <div class="chart-wrap" style="height:320px">
            <canvas id="chartCat"></canvas>
        </div>
        <div class="card-footer">
            <span class="text-mono text-faint" style="font-size:9px">Suma acumulada por grupo · top @Math.Min(Model.Categorias.Count,12)</span>
        </div>
    </div>

    <!-- Doughnut: fuentes -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--copper)"></span>
                Distribución por fuente
            </div>
        </div>
        <div class="chart-wrap" style="height:280px; display:flex; align-items:center; justify-content:center">
            <canvas id="chartFuente"></canvas>
        </div>
        <div class="card-footer">
            <span class="text-mono text-faint" style="font-size:9px">% de registros por origen</span>
        </div>
    </div>
</div>

<!-- ─── LINE CHART ────────────────────────────────────────── -->
@if (Model.Fechas.Any())
{
    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <span class="card-title-accent" style="background:var(--malachite)"></span>
                Tendencia temporal
                <span style="color:var(--chalk-faint); font-weight:300">— valor acumulado por período</span>
            </div>
            <span class="tag tag-malachite" style="font-size:9px">@Model.Fechas.Count períodos</span>
        </div>
        <div class="chart-wrap" style="height:240px">
            <canvas id="chartFecha"></canvas>
        </div>
    </div>
}

<!-- ─── STATS TABLE ───────────────────────────────────────── -->
<div class="card">
    <div class="card-header">
        <div class="card-title">
            <span class="card-title-accent" style="background:var(--sapphire)"></span>
            Resumen estadístico por categoría
        </div>
        <a href="/descargar-estadisticas" class="btn btn-ghost btn-sm">
            <i class="bi bi-download" style="font-size:10px"></i>
            Descargar
        </a>
    </div>
    <div class="table-scroll" style="max-height:400px">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Categoría</th>
                    <th style="text-align:right">Cantidad</th>
                    <th style="text-align:right">Total</th>
                    <th style="text-align:right">Barra relativa</th>
                </tr>
            </thead>
            <tbody>
                @{
                    double maxTotal = Model.Totales.Any() ? Model.Totales.Max() : 1;
                    for (int i = 0; i < Model.Categorias.Count; i++)
                    {
                        string color = palette[i % palette.Length];
                        double pct = maxTotal > 0 ? (Model.Totales[i] / maxTotal * 100) : 0;
                        <tr>
                            <td>
                                <div class="flex gap-2 items-center">
                                    <div class="src-dot" style="background:@color; border-radius:2px; width:8px; height:8px; flex-shrink:0"></div>
                                    <span style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">@Model.Categorias[i]</span>
                                </div>
                            </td>
                            <td class="num-cell">—</td>
                            <td class="val-cell">@Model.Totales[i].ToString("N2")</td>
                            <td style="min-width:120px; padding-right:16px">
                                <div class="flex gap-2 items-center">
                                    <div class="mini-bar-wrap" style="flex:1">
                                        <div class="mini-bar" style="width:@pct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%; background:@color"></div>
                                    </div>
                                    <span class="text-mono text-faint" style="font-size:9px; min-width:32px; text-align:right">@pct.ToString("F0")%</span>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
const PAL = @Html.Raw(paletteJson);
const GRID = 'rgba(255,255,255,0.05)';

const tip = {
    backgroundColor: '#1a1a26',
    borderColor: '#32324a',
    borderWidth: 1,
    borderRadius: 4,
    padding: 10,
    titleColor: '#d4ff00',
    titleFont: { family: "'JetBrains Mono'", size: 10, weight: '500' },
    bodyColor: '#e8e8f0',
    bodyFont: { family: "'JetBrains Mono'", size: 10 }
};

const scaleX = {
    grid: { color: GRID, drawBorder: false },
    ticks: { font: { family: "'JetBrains Mono'", size: 9 }, color: '#9090a8', maxRotation: 45 }
};

const scaleY = {
    grid: { color: GRID, drawBorder: false },
    ticks: {
        font: { family: "'JetBrains Mono'", size: 9 }, color: '#9090a8',
        callback: v => v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v
    }
};

/* ── Bar: categorías ── */
new Chart(document.getElementById('chartCat'), {
    type: 'bar',
    data: {
        labels: @Html.Raw(catJson),
        datasets: [{
            label: 'Valor total',
            data: @Html.Raw(totJson),
            backgroundColor: PAL.map(c => c + '26'),
            borderColor: PAL,
            borderWidth: 1,
            borderRadius: 2,
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: tip },
        scales: { x: scaleX, y: scaleY }
    }
});

/* ── Doughnut: fuentes ── */
new Chart(document.getElementById('chartFuente'), {
    type: 'doughnut',
    data: {
        labels: @Html.Raw(fuenteJson),
        datasets: [{
            data: @Html.Raw(conteoJson),
            backgroundColor: PAL.slice(0, @Model.Fuentes.Count).map(c => c + '33'),
            borderColor: PAL.slice(0, @Model.Fuentes.Count),
            borderWidth: 1,
            hoverBorderWidth: 2,
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false, cutout: '68%',
        plugins: {
            legend: {
                position: 'bottom',
                labels: {
                    font: { family: "'JetBrains Mono'", size: 9 },
                    color: '#9090a8', padding: 12, boxWidth: 10, usePointStyle: true
                }
            },
            tooltip: {
                ...tip,
                callbacks: {
                    label: ctx => {
                        const tot = ctx.dataset.data.reduce((a,b) => a+b, 0);
                        const pct = ((ctx.parsed/tot)*100).toFixed(1);
                        return ` ${ctx.label}: ${ctx.parsed} (${pct}%)`;
                    }
                }
            }
        }
    }
});

@if (Model.Fechas.Any())
{
    <text>
/* ── Line: temporal ── */
new Chart(document.getElementById('chartFecha'), {
    type: 'line',
    data: {
        labels: @Html.Raw(fechasJson),
        datasets: [{
            label: 'Valor acumulado',
            data: @Html.Raw(valFecJson),
            borderColor: '#00d48a',
            backgroundColor: 'rgba(0,212,138,0.08)',
            fill: true, tension: 0.4,
            pointRadius: 4, pointBackgroundColor: '#00d48a',
            pointBorderColor: '#0a0a0f', pointBorderWidth: 2,
            pointHoverRadius: 6
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: tip },
        scales: { x: scaleX, y: scaleY }
    }
});
    </text>
}
</script>
}
