@model GraficasViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Gráficas";
    var catJson    = JsonSerializer.Serialize(Model.Categorias);
    var totJson    = JsonSerializer.Serialize(Model.Totales);
    var fuenteJson = JsonSerializer.Serialize(Model.Fuentes);
    var conteoJson = JsonSerializer.Serialize(Model.ConteoFuente);
    var fechasJson = JsonSerializer.Serialize(Model.Fechas);
    var valFecJson = JsonSerializer.Serialize(Model.ValoresFecha);

    var palette = new[]{"#00c8dc","#ffc832","#00e080","#ff5064",
                        "#b464ff","#ff9632","#00dcc8","#dc50dc",
                        "#50c850","#6496ff","#ff6e6e","#64ffb4"};
    var paletteJson = JsonSerializer.Serialize(palette);
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 style="color:var(--cyan)"><i class="bi bi-bar-chart-fill me-2"></i>Gráficas</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-table"></i> Ver Tabla
    </a>
</div>

<!-- Tarjetas resumen -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3">
            <div class="stat-num">@Model.TotalItems.ToString("N0")</div>
            <div class="small text-muted">Total registros</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3" style="border-color:var(--yellow)">
            <div class="stat-num" style="color:var(--yellow)">@Model.Categorias.Count</div>
            <div class="small text-muted">Categorías</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3" style="border-color:var(--green)">
            <div class="stat-num" style="color:var(--green)">@Model.Fuentes.Count</div>
            <div class="small text-muted">Fuentes</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3" style="border-color:#ff5064">
            <div class="stat-num" style="color:#ff5064">@Model.Fechas.Count</div>
            <div class="small text-muted">Períodos</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Gráfica 1: Barras por categoría -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header fw-bold">
                <i class="bi bi-bar-chart me-1" style="color:var(--cyan)"></i>
                Valor Total por Categoría
            </div>
            <div class="card-body">
                <canvas id="chartCat" style="max-height:320px"></canvas>
            </div>
        </div>
    </div>

    <!-- Gráfica 2: Dona por fuente -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header fw-bold">
                <i class="bi bi-pie-chart me-1" style="color:var(--yellow)"></i>
                Registros por Fuente
            </div>
            <div class="card-body d-flex align-items-center">
                <canvas id="chartFuente" style="max-height:280px"></canvas>
            </div>
        </div>
    </div>

    <!-- Gráfica 3: Línea por fecha -->
    @if (Model.Fechas.Any())
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-bold">
                    <i class="bi bi-graph-up me-1" style="color:var(--green)"></i>
                    Valor Acumulado por Período (Mes)
                </div>
                <div class="card-body">
                    <canvas id="chartFecha" style="max-height:240px"></canvas>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
const PALETTE = @Html.Raw(paletteJson);
const dark = '#12121c', grid = '#2a2a3c', fg = '#e6e6f0';

Chart.defaults.color = fg;
Chart.defaults.font.family = "'Segoe UI', sans-serif";

// Plugins comunes
const tooltipDark = {
    backgroundColor: '#1c1c2a',
    borderColor: '#3a3a58',
    borderWidth: 1,
    titleColor: '#00c8dc',
    bodyColor: '#e6e6f0'
};

// ── 1. Barras por categoría ──────────────────────────────────
new Chart(document.getElementById('chartCat'), {
    type: 'bar',
    data: {
        labels: @Html.Raw(catJson),
        datasets: [{
            label: 'Valor Total',
            data: @Html.Raw(totJson),
            backgroundColor: PALETTE,
            borderWidth: 0,
            borderRadius: 4
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { display: false },
            tooltip: { ...tooltipDark,
                callbacks: {
                    label: ctx => ` ${ctx.parsed.y.toLocaleString('es-MX', {minimumFractionDigits:2})}`
                }
            }
        },
        scales: {
            x: { grid: { color: grid }, ticks: { maxRotation: 40 } },
            y: { grid: { color: grid },
                 ticks: { callback: v => v >= 1e6 ? (v/1e6).toFixed(1)+'M'
                                        : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v }
               }
        }
    }
});

// ── 2. Dona por fuente ───────────────────────────────────────
new Chart(document.getElementById('chartFuente'), {
    type: 'doughnut',
    data: {
        labels: @Html.Raw(fuenteJson),
        datasets: [{
            data: @Html.Raw(conteoJson),
            backgroundColor: PALETTE,
            borderWidth: 2,
            borderColor: dark
        }]
    },
    options: {
        responsive: true,
        cutout: '60%',
        plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 12, padding: 10 } },
            tooltip: tooltipDark
        }
    }
});

@if (Model.Fechas.Any())
{
    // ── 3. Línea temporal ────────────────────────────────────
    <text>
    new Chart(document.getElementById('chartFecha'), {
        type: 'line',
        data: {
            labels: @Html.Raw(fechasJson),
            datasets: [{
                label: 'Valor',
                data: @Html.Raw(valFecJson),
                borderColor: '#00e080',
                backgroundColor: 'rgba(0,224,128,.12)',
                fill: true,
                tension: .4,
                pointRadius: 4,
                pointBackgroundColor: '#00e080'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: tooltipDark
            },
            scales: {
                x: { grid: { color: grid } },
                y: { grid: { color: grid } }
            }
        }
    });
    </text>
}
</script>
}
